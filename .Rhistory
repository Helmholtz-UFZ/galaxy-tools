plotdata <- readRDS(plotdata_file)
# load the plotdata table that is used to fit the model
plotdata_file <- file.path("Y:/Gruppen/etox/AG_mTox/Jana/neuroBEAT_pyCharm/PowerAnalysis", "result_files", "gam", "20250317_plotdata_before_model.rds")
plotdata <- readRDS(plotdata_file)
View(plotdata)
###################### Simulate the data ############################################
# Extract unique combinations of time, var1, and phase
unique_combinations <- unique(plotdata[, c("time", "var1", "phase")])
new_df <- plotdata[, c("animalID", "time", "chemical",
"var1", "phase")]
# Simpler animalID for new sample sizes
# Desired number of animals
n_animals <- 35
unique_var1 <- unique(plotdata$var1)
new_animalIDs <- unlist(lapply(unique_var1, function(v) {
paste0(v, "_Animal", seq_len(n_animals))  # Generate n_animals IDs per var1
}))
# For each unique combination of time, var1, and phase, assign all animalIDs
expanded_df <- do.call(rbind,
lapply(seq_len(nrow(unique_combinations)), function(i) { # Get the current combination
combo <- unique_combinations[i,]
# Filter animalIDs that match the current `var1`
current_animalIDs <- new_animalIDs[grepl(paste0("^", combo$var1, "_"), new_animalIDs)]
# Create a dataframe for this combination with all its animalIDs
data.frame(
time = combo$time,
var1 = combo$var1,
phase = combo$phase,
animalID = current_animalIDs
)
}
)
)
View(expanded_df)
# Identify any extra columns in `plotdata` that we need to add back
extra_columns <- setdiff(names(new_df), c("time", "var1", "phase", "animalID"))
# Merge each column back into the expanded dataset
for (col in extra_columns) {
expanded_df[[col]] <- plotdata[[col]][
match(interaction(expanded_df$time, expanded_df$var1, expanded_df$phase),
interaction(plotdata$time, plotdata$var1, plotdata$phase))
]
}
######################## Extracting the standard deviations ###############################
# Standard deviation of random effects
sd_re <- gam.vcomp(model)
