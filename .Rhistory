library(mgcv)
library(mgcv)
library(extraDistr)
######################## Extracting the standard deviations ###############################
# Standard deviation of random effects
sd_re <- gam.vcomp(model)
# Standard deviation of residuals
stD_residuals <- sd(model$residual) # deviance residuals
# model$y are the scaled_values used to fit the model
# standard deviation of difference between predictions and real values
residuals_pred <- car::logit(model$y) - predict(model, type = "link")
summary(model)
