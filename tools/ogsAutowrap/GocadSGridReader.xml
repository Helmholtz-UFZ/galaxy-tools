<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: GocadSGridReader" id="ogs_gocadsgridreader" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'GocadSGridReader'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[GocadSGridReader --version]]></version_command>
  <command><![CDATA[
ln -sf '$sg' '$sg.element_identifier';
GocadSGridReader
    $generate_face_sets
    --sg '$sg.element_identifier'
    --output-mesh output_1.vtu
]]></command>
  <inputs>
    <param argument="--generate-face-sets" type="boolean" label="generate face sets" help="Generate face sets." checked="false" truevalue="--generate-face-sets" falsevalue="" />
    <param argument="--sg" type="data" optional="false" label="sg" help="Input (.sg). Gocad stratigraphic grid filename" format="gocad.sg" />
  </inputs>
  <outputs>
    <data name="output_GocadSGridReader" format="vtkxml" label="Output from GocadSGridReader" from_work_dir="output_1.vtu" hidden="false" />
  </outputs>
  <tests>
    <expand macro="gocadsgridreader_test" />
  </tests>
  <help>This tool runs the **GocadSGridReader** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>