<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: Mesh2Raster" id="ogs_mesh2raster" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'Mesh2Raster'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[Mesh2Raster --version]]></version_command>
  <command><![CDATA[
ln -s '$input_file' '$input_file.element_identifier';
Mesh2Raster
    $cellsize: --cellsize '$cellsize'
    --input-file '$input_file.element_identifier'
    --output-file output_1.asc
]]></command>
  <inputs>
    <param name="cellsize" type="float" optional="true" label="cellsize" help="edge length of raster cells in result. (min = 0)" />
    <param name="input_file" type="data" optional="false" label="input file" help="Input (.vtu | .msh). Mesh input file" format="vtkxml" multiple="false" />
  </inputs>
  <outputs>
    <data name="output_Mesh2Raster" format="asc" label="Output from Mesh2Raster" from_work_dir="output_1.asc" hidden="false" />
  </outputs>
  <tests>
    <expand macro="mesh2raster_test" />
  </tests>
  <help>This tool runs the **Mesh2Raster** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>