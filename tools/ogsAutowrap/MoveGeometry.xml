<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: MoveGeometry" id="ogs_movegeometry" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'MoveGeometry'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[MoveGeometry --version]]></version_command>
  <command><![CDATA[
ln -s '$input' '$input.element_identifier';
MoveGeometry
    $z: --z '$z'
    $y: --y '$y'
    $x: --x '$x'
    --input '$input.element_identifier'
    --output output_1.gml
]]></command>
  <inputs>
    <param name="z" type="float" optional="true" label="z" help="displacement in z direction" />
    <param name="y" type="float" optional="true" label="y" help="displacement in y direction" />
    <param name="x" type="float" optional="true" label="x" help="displacement in x direction" />
    <param name="input" type="data" optional="false" label="input" help="Input (.gml) geometry file" format="xml" multiple="false" />
  </inputs>
  <outputs>
    <data name="output_MoveGeometry" format="xml" label="Output from MoveGeometry" from_work_dir="output_1.gml" hidden="false" />
  </outputs>
  <tests>
    <expand macro="movegeometry_test" />
  </tests>
  <help>This tool runs the **MoveGeometry** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>