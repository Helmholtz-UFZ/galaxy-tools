<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: MoveMesh" id="ogs_movemesh" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'MoveMesh'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[MoveMesh --version]]></version_command>
  <command><![CDATA[
ln -s '$mesh' '$mesh.element_identifier';
MoveMesh
    --mesh '$mesh.element_identifier'
    $x: --x '$x'
    $y: --y '$y'
    $z: --z '$z'
    --output-mesh output_1.vtu
]]></command>
  <inputs>
    <param name="mesh" type="data" optional="false" label="mesh" help="Input (.vtu) mesh file" format="vtkxml" multiple="false" />
    <param name="x" type="float" optional="true" label="x" help="displacement in x direction" />
    <param name="y" type="float" optional="true" label="y" help="displacement in y direction" />
    <param name="z" type="float" optional="true" label="z" help="displacement in z direction" />
  </inputs>
  <outputs>
    <data name="output_MoveMesh" format="vtkxml" label="Output from MoveMesh" from_work_dir="output_1.vtu" hidden="false" />
  </outputs>
  <tests>
    <expand macro="movemesh_test" />
  </tests>
  <help>This tool runs the **MoveMesh** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>