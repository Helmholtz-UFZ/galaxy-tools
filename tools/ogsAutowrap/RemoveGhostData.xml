<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: RemoveGhostData" id="ogs_removeghostdata" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'RemoveGhostData'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[RemoveGhostData --version]]></version_command>
  <command><![CDATA[
ln -sf '$input' '$input.element_identifier';
RemoveGhostData
    --input '$input.element_identifier'
    --output output_1.vtu
]]></command>
  <inputs>
    <param argument="--input" type="data" optional="false" label="input" help="Input (.pvtu). The partitioned input mesh file" format="vtkxml" />
  </inputs>
  <outputs>
    <data name="output_RemoveGhostData" format="vtkxml" label="Output from RemoveGhostData" from_work_dir="output_1.vtu" hidden="false" />
  </outputs>
  <tests>
    <expand macro="removeghostdata_test" />
  </tests>
  <help>This tool runs the **RemoveGhostData** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>