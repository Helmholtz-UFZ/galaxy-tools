<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: TecPlotTools" id="ogs_tecplottools" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'TecPlotTools'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[TecPlotTools --version]]></version_command>
  <command><![CDATA[
ln -sf '$input_file' '$input_file.element_identifier';
TecPlotTools
    $split
    $convert
    --input-file '$input_file.element_identifier'
    --output-file output_1.vtu
]]></command>
  <inputs>
    <param name="split" type="boolean" label="split" help="split time steps into separate files" checked="false" truevalue="--split" falsevalue="" />
    <param name="convert" type="boolean" label="convert" help="convert TecPlot data into OGS meshes" checked="false" truevalue="--convert" falsevalue="" />
    <param name="input_file" type="data" optional="false" label="input file" help="Input (.plt). TecPlot input file" format="txt" />
  </inputs>
  <outputs>
    <data name="output_TecPlotTools" format="vtkxml" label="Output from TecPlotTools" from_work_dir="output_1.vtu" hidden="false" />
  </outputs>
  <tests>
    <expand macro="tecplottools_test" />
  </tests>
  <help>This tool runs the **TecPlotTools** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>