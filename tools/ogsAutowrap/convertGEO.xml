<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: convertGEO" id="ogs_convertgeo" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'convertGEO'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[convertGEO --version]]></version_command>
  <command><![CDATA[
ln -sf '$input_file' '$input_file.element_identifier';
ln -sf '$gmsh_path' '$gmsh_path.element_identifier';
convertGEO
    --input-file '$input_file.element_identifier'
    --gmsh-path '$gmsh_path.element_identifier'
    --output-file output_1.vtu
]]></command>
  <inputs>
    <param name="input_file" type="data" optional="false" label="input file" help="Input (.gml|.gli). The name of the geometry file to be converted" format="xml" multiple="false" />
    <param name="gmsh_path" type="data" optional="false" label="gmsh path" help="Input (.msh). The path to the gmsh binary file" format="msh" multiple="false" />
  </inputs>
  <outputs>
    <data name="output_convertGEO" format="vtkxml" label="Output from convertGEO" from_work_dir="output_1.vtu" hidden="false" />
  </outputs>
  <tests>
    <expand macro="convertgeo_test" />
  </tests>
  <help>This tool runs the **convertGEO** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>