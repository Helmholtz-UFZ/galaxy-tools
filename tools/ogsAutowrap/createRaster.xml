<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: createRaster" id="ogs_createraster" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'createRaster'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[createRaster --version]]></version_command>
  <command><![CDATA[
createRaster
    $n_rows: --n_rows '$n_rows'
    $n_cols: --n_cols '$n_cols'
    $cell_size: --cell_size '$cell_size'
    $ll_y: --ll_y '$ll_y'
    $ll_x: --ll_x '$ll_x'
    --output output_1.asc
]]></command>
  <inputs>
    <param name="n_rows" type="integer" optional="true" label="n rows" help="number of rows" />
    <param name="n_cols" type="integer" optional="true" label="n cols" help="number of columns" />
    <param name="cell_size" type="float" optional="true" label="cell size" help="cell size, (min = 0)" />
    <param name="ll_y" type="float" optional="true" label="ll y" help="y coordinate of lower left point of axis aligned rectangular region" />
    <param name="ll_x" type="float" optional="true" label="ll x" help="x coordinate of lower left point of axis aligned rectangular region" />
  </inputs>
  <outputs>
    <data name="output_createRaster" format="asc" label="Output from createRaster" from_work_dir="output_1.asc" hidden="false" />
  </outputs>
  <tests>
    <expand macro="createraster_test" />
  </tests>
  <help>This tool runs the **createRaster** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>