<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: editMaterialID" id="ogs_editmaterialid" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'editMaterialID'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[editMaterialID --version]]></version_command>
  <command><![CDATA[
ln -sf '$mesh_input_file' '$mesh_input_file.element_identifier';
editMaterialID
    $replace
    $condense
    $specify
    --mesh-input-file '$mesh_input_file.element_identifier'
    --current-material-id '$current_material_id'
    --new-material-id '$new_material_id'
    --element-type '$element_type'
    --mesh-output-file output_1.vtu
]]></command>
  <inputs>
    <param name="replace" type="boolean" label="replace" help="replace material IDs" checked="false" truevalue="--replace" falsevalue="" />
    <param name="condense" type="boolean" label="condense" help="condense material IDs" checked="false" truevalue="--condense" falsevalue="" />
    <param name="specify" type="boolean" label="specify" help="specify material IDs by element types (-e)" checked="false" truevalue="--specify" falsevalue="" />
    <param name="mesh_input_file" type="data" optional="false" label="mesh input file" help="Input (.vtu | .msh). The name of the file containing the input mesh" format="vtkxml" />
    <param name="current_material_id" type="text" optional="true" label="current material id" help="current material id to be replaced" />
    <param name="new_material_id" type="text" optional="true" label="new material id" help="new material id" />
    <param name="element_type" type="select" optional="false" label="element type" help="element type">
      <option value="point">point</option>
      <option value="line">line</option>
      <option value="quad">quad</option>
      <option value="hex">hex</option>
      <option value="tri">tri</option>
      <option value="tet">tet</option>
      <option value="pris">pris</option>
      <option value="pyra">pyra</option>
    </param>
  </inputs>
  <outputs>
    <data name="output_editMaterialID" format="vtkxml" label="Output from editMaterialID" from_work_dir="output_1.vtu" hidden="false" />
  </outputs>
  <tests>
    <expand macro="editmaterialid_test" />
  </tests>
  <help>This tool runs the **editMaterialID** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>