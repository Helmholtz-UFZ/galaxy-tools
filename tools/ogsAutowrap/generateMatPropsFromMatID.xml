<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: generateMatPropsFromMatID" id="ogs_generatematpropsfrommatid" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'generateMatPropsFromMatID'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[generateMatPropsFromMatID --version]]></version_command>
  <command><![CDATA[
ln -sf '$mesh' '$mesh.element_identifier';
generateMatPropsFromMatID
    --mesh '$mesh.element_identifier'
]]></command>
  <inputs>
    <param argument="--mesh" type="data" optional="true" label="mesh" help="Input (.msh). The mesh to open from a file" format="msh" />
  </inputs>
  <outputs>
    <collection name="tool_outputs" type="list" label="Outputs from generateMatPropsFromMatID">
      <discover_datasets pattern="(?P&lt;designation&gt;.*)\.vtu" format="vtkxml" visible="true" />
    </collection>
  </outputs>
  <tests>
    <expand macro="generatematpropsfrommatid_test" />
  </tests>
  <help>This tool runs the **generateMatPropsFromMatID** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>