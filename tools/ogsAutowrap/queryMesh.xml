<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: queryMesh" id="ogs_querymesh" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'queryMesh'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[queryMesh --version]]></version_command>
  <command><![CDATA[
ln -sf '$mesh_file' '$mesh_file.element_identifier';
queryMesh
     --element-id '$element_id'
     --node-id '$node_id'
    $show_node_with_max_elements
    -- '$mesh_file.element_identifier'
]]></command>
  <inputs>
    <param name="element_id" type="integer" optional="true" label="element id" help="element ID" />
    <param name="node_id" type="integer" optional="true" label="node id" help="node ID" />
    <param name="show_node_with_max_elements" type="boolean" label="show node with max elements" help="show a node having the max number of connected elements" checked="false" truevalue="--show-node-with-max-elements" falsevalue="" />
    <param name="mesh_file" type="data" optional="false" label="mesh file" help="Input (.vtu) mesh file" format="vtkxml" multiple="false" />
  </inputs>
  <outputs />
  <tests>
    <expand macro="querymesh_test" />
  </tests>
  <help>This tool runs the **queryMesh** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>