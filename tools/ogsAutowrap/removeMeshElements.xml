<?xml version="1.0" encoding="UTF-8"?>
<tool name="OGS: removeMeshElements" id="ogs_removemeshelements" version="@TOOL_VERSION@+galaxy@VERSION_SUFFIX@" profile="22.01">
  <description>Galaxy wrapper for the OGS utility 'removeMeshElements'.</description>
  <macros>
    <import>macros.xml</import>
    <import>test_macros.xml</import>
  </macros>
  <expand macro="requirements" />
  <version_command><![CDATA[removeMeshElements --version]]></version_command>
  <command><![CDATA[
ln -sf '$mesh_input_file' '$mesh_input_file.element_identifier';
removeMeshElements
    $invert
    $zero_volume
    --element-type '$element_type'
    --property-name '$property_name'
    --property-value '$property_value'
    --min-value '$min_value'
    --max-value '$max_value'
    $outside
    $inside
    --mesh-input-file '$mesh_input_file.element_identifier'
    --mesh-output-file output_1.vtu
]]></command>
  <inputs>
    <param argument="--invert" type="boolean" label="invert" help="inverts the specified bounding box" checked="false" truevalue="--invert" falsevalue="" />
    <param argument="--zero-volume" type="boolean" label="zero volume" help="remove zero volume elements" checked="false" truevalue="--zero-volume" falsevalue="" />
    <param argument="--element-type" type="select" optional="true" label="element type" help="element type to be removed" multiple="true">
      <option value="point">point</option>
      <option value="line">line</option>
      <option value="tri">tri</option>
      <option value="quad">quad</option>
      <option value="hex">hex</option>
      <option value="prism">prism</option>
      <option value="tet">tet</option>
      <option value="pyramid">pyramid</option>
    </param>
    <param argument="--property-name" type="text" optional="true" label="property name" help="name of property in the mesh" />
    <param argument="--property-value" type="integer" optional="true" label="property value" help="value of selected property to be removed" />
    <param argument="--min-value" type="float" optional="true" label="min value" help="minimum value of range for selected property" />
    <param argument="--max-value" type="float" optional="true" label="max value" help="maximum value of range for selected property" />
    <param argument="--outside" type="boolean" label="outside" help="remove all elements outside the given property range" checked="false" truevalue="--outside" falsevalue="" />
    <param argument="--inside" type="boolean" label="inside" help="remove all elements inside the given property range" checked="false" truevalue="--inside" falsevalue="" />
    <param argument="--mesh-input-file" type="data" optional="false" label="mesh input file" help="Input (.vtu). The name of the file containing the input mesh" format="vtkxml" />
  </inputs>
  <outputs>
    <data name="output_removeMeshElements" format="vtkxml" label="Output from removeMeshElements" from_work_dir="output_1.vtu" hidden="false" />
  </outputs>
  <tests>
    <expand macro="removemeshelements_test" />
  </tests>
  <help>This tool runs the **removeMeshElements** utility from the OpenGeoSys suite.</help>
  <expand macro="citations" />
</tool>